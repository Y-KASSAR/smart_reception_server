# .env.example - Template for environment variables
# Copy this to .env and fill in your actual values
# NEVER commit .env to Git!

# --- API Authentication ---
# Shared secret between RPi edge device and laptop server
API_KEY=test_api_key_12345
# Secret key for signing JWT tokens (generate a random 64-char string)
JWT_SECRET_KEY=super_secret_jwt_key_for_development_only_change_in_production

# --- Email (SMTP) Configuration ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_RECIPIENTS=manager1@hotel.com,manager2@hotel.com


# --- Twilio (SMS) Configuration ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
ALERT_SMS_RECIPIENTS=

# --- Encryption Key (for facial embedding encryption at rest) ---
ENCRYPTION_KEY=dGhpc19pc19hX3Rlc3Rfa2V5X2Zvcl9kZXY

# --- Default Admin Account (change password after first login!) ---
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin