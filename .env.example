# .env.example - Template for environment variables
# Copy this to .env and fill in your actual values
# NEVER commit .env to Git!
# --- API Authentication ---
# Shared secret between RPi edge device and laptop server
API_KEY=your_secure_random_api_key_here
# Secret key for signing JWT tokens (generate a random 64-char string)
JWT_SECRET_KEY=your_jwt_secret_key_here
# --- Email (SMTP) Configuration ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
ALERT_EMAIL_RECIPIENTS=manager1@hotel.com,manager2@hotel.com
# --- Twilio (SMS) Configuration ---
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890
ALERT_SMS_RECIPIENTS=+9611234567,+9617654321
# --- Encryption Key (for facial embedding encryption at rest) ---
ENCRYPTION_KEY=your_32_byte_base64_key_here
# --- Default Admin Account (change password after first login!) ---
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change_me_immediately